# Домен, на который указывает A-запись сервера (Caddy сам выпустит TLS-сертификат)
DOMAIN=skillproof.example.ru

# Пароль для Postgres в docker-compose (придумайте свой)
POSTGRES_PASSWORD=

# Ключ доступа к админке /admin/results (придумайте свой)
RESULTS_API_KEY=

# Отправка писем с результатами через Resend (опционально — без ключа письма просто не шлются)
RESEND_API_KEY=
RESULT_EMAIL_FROM=SkillProof <onboarding@resend.dev>

# AI-оценка открытых ответов через Vercel AI Gateway (опционально —
# без ключа грейдер выставляет нейтральные 50 баллов, поток не ломается).
# Ключ: https://vercel.com/dashboard -> AI Gateway -> API Keys
AI_GATEWAY_API_KEY=
