# ─────────────────────────────────────────────────────────────
# SkillProof — пример переменных окружения
# Скопируйте этот файл в .env.local и заполните значения.
# НЕ коммитьте .env.local — он игнорируется git (.env*.local).
# ─────────────────────────────────────────────────────────────

# ── Обязательные ──────────────────────────────────────────────

# Neon Postgres: строка подключения.
# При подключении интеграции Neon в v0/Vercel задаётся автоматически.
# Формат: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Ключ доступа к админ-разделу /admin/results и к API прокторинга/результатов
# (он же используется как пароль входа администратора).
# Сгенерировать: openssl rand -base64 32
RESULTS_API_KEY="change-me-to-a-long-random-string"

# ── Необязательные ────────────────────────────────────────────

# Resend API ключ для отправки писем с результатами.
# Если не задан — отправка писем просто пропускается.
RESEND_API_KEY=""

# Адрес отправителя для писем с результатами.
# По умолчанию: "SkillProof <onboarding@resend.dev>"
RESULT_EMAIL_FROM=""

# Включает E2E-режим тестирования (работает только вне production).
# Значения: "true" или "1".
NEXT_PUBLIC_E2E_TEST_MODE=""
